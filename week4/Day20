        while(!q.isEmpty()){
            int node = q.poll();
            System.out.print(node + " ");

            for(int neigh : graph.get(node)){
                if(!visited[neigh]){
                    visited[neigh] = true;
                    q.add(neigh);
                }
            }
        }
    }
}
