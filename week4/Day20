import java.util.*;

class MinStack {
    Stack<Integer> main = new Stack<>();
    Stack<Integer> min = new Stack<>();

    void push(int x){
        main.push(x);

        if(min.isEmpty() || x <= min.peek()){
            min.push(x);
        }
    }

    void pop(){
        if(main.peek().equals(min.peek())){
            min.pop();
        }
        main.pop();
    }

    int getMin(){
        return min.peek();
    }

    public static void main(String[] args) {
        MinStack s = new MinStack();

        s.push(5);
        s.push(2);
        s.push(8);

        System.out.println("Min: " + s.getMin());
    }
}
