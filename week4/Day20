        String s = "()[]{}";

        Stack<Character> st = new Stack<>();

        for(char c : s.toCharArray()){
            if(c=='(' || c=='[' || c=='{'){
                st.push(c);
            } else {
                if(st.isEmpty()){
                    System.out.println("Invalid");
